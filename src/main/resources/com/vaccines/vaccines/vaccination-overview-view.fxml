<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>

<?import javafx.scene.text.Text?>
<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.vaccines.vaccines.controller.VaccinationOverviewController"
      alignment="CENTER"
      spacing="20"
      style="-fx-padding: 40;"
      stylesheets="@style.css">

    <ImageView fitWidth="150" preserveRatio="true">
        <image>
            <Image url="@Logo_transparent.png"/>
        </image>
    </ImageView>

    <Label fx:id="profileNameLabel" text="Impfübersicht"/>
    <TableView fx:id="vaccinationTable" prefHeight="400" style="-fx-alignment: CENTER;">
        <columns>
            <TableColumn fx:id="nameColumn" text="Impfstoff" prefWidth="200"/>
            <TableColumn fx:id="diseaseColumn" text="Krankheit" prefWidth="200"/>
            <TableColumn fx:id="lastColumn" text="Letzte Impfung" prefWidth="150"/>
            <TableColumn fx:id="nextColumn" text="Nächste fällig" prefWidth="150"/>
            <TableColumn fx:id="statusColumn" text="Status" prefWidth="100"/>
            <TableColumn fx:id="deleteColumn" text="Löschen" prefWidth="60"/>
        </columns>
    </TableView>
    <Text
            text="⚠ Hinweis: Diese App ersetzt keine ärztliche Beratung. Alle Angaben sind unverbindliche Empfehlungen basierend auf STIKO/StIKo Vet Richtlinien. Bitte konsultiere vor jeder Impfentscheidung einen entsprechenden Arzt."
            style="-fx-font-size: 10px; -fx-fill: gray;"
            wrappingWidth="600"
            textAlignment="CENTER"/>
    <HBox alignment="CENTER" spacing="10">
    <Button text="Zurück" onAction="#handleZurueck"/>
    <Button text="+ Impfung hinzufügen" onAction="#handleImpfungHinzufuegen"/>
    <Button text="Profil löschen" onAction="#handleProfilLoeschen"/>
    </HBox>

</VBox>